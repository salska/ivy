{
  "theme": "San Francisco / Ivory Blackboard",
  "colors": {
    "background": "#F5F5F7",
    "surface": "#FFFFFF",
    "primary": "#0071E3",
    "secondary": "#86868B",
    "success": "#34C759",
    "warning": "#FF9500",
    "error": "#FF3B30",
    "border": "#D2D2D7"
  },
  "typography": {
    "font_family": "SF Pro Display, system-ui",
    "base_size": "14px",
