{
  "name": "ivy-blackboard",
  "version": "0.3.0",
  "description": "ivy — Unified Personal AI Infrastructure: blackboard kernel + heartbeat runtime with plugin system and multi-brain support",
  "type": "module",
  "main": "src/kernel/kernel.ts",
  "module": "src/kernel/kernel.ts",
  "exports": {
    "./src/*": "./src/*.ts",
    "./src/*/index.ts": "./src/*/index.ts"
  },
  "bin": {
    "ivy": "src/cli.ts",
    "blackboard": "src/kernel/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "serve": "lsof -ti:7878 | xargs kill -9 2>/dev/null || true; bun run src/cli.ts serve --dispatch",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "ci": "bun test && bunx tsc --noEmit",
    "build": "bun test && bunx tsc --noEmit && ./build.sh"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jcfischer/ivy-blackboard.git"
  },
  "homepage": "https://github.com/jcfischer/ivy-blackboard",
  "bugs": {
    "url": "https://github.com/jcfischer/ivy-blackboard/issues"
  },
  "author": "Jens-Christian Fischer",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "pai-content-filter": "github:jcfischer/pai-content-filter",
    "playright": "^0.0.22",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/minimatch": "^5.1.2",
    "typescript": "^5.7"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}